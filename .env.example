PORT=5050
NODE_ENV=development
DATABASE_URL=postgresql://postgres:password@localhost:5432/verifund
VERIFUND_FORCE_MEMORY=1
JWT_SECRET=replace-with-a-long-random-secret
CORS_ORIGIN=http://localhost:5173
NOMBA_CLIENT_ID=replace-with-your-nomba-client-id
NOMBA_CLIENT_SECRET=replace-with-your-nomba-client-secret
NOMBA_ACCOUNT_ID=replace-with-your-nomba-account-id
NOMBA_WEBHOOK_SECRET=replace-with-your-nomba-webhook-secret
NOMBA_ALLOW_MOCK_FALLBACK=true
# sandbox or production. Leave as sandbox until you're ready to go live.
NOMBA_ENV=sandbox
# Header name Nomba sends the webhook signature in. Confirm the exact name in your Nomba
# dashboard's webhook settings and update this if it differs from "signature".
NOMBA_SIGNATURE_HEADER=signature
VITE_API_BASE_URL=http://localhost:5050/api
VITE_WS_URL=ws://localhost:5050/ws
